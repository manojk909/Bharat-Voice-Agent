# Vultr Object Storage
VULTR_S3_ENDPOINT=https://ewr1.vultrobjects.com
VULTR_S3_ACCESS_KEY=your_vultr_access_key
VULTR_S3_SECRET_KEY=your_vultr_secret_key
VULTR_S3_BUCKET_NAME=bharat-voice-assets

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=bharat_voice_agent

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# n8n Webhook
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/evaluate
